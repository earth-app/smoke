# This is an example environment file for testing. You can copy this to .env.test and fill in the values for production.
# Do not use these values in production, they are not secure.

# Can be any string, treat it like a passphrase.
# Best practice is to generate a random base64 or hex string of at least 32 bytes (64 characters in hex),
# required to be at least 16 chracters.
# Used for encrypting sensitive data, and should be kept secret.
MASTER_KEY=1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Must be a valid hex string of at least 32 bytes (64 characters in hex).
# You can generate a secure random key by running `openssl rand -hex 32` in your terminal.
# Used for generating HMAC hashes for email address lookup, and should be kept secret.
HMAC_SECRET=3b6dfd1e6125a582a19411ec7d1b0e0083cc1ceb430dba3a8c107d826ced491d

# Email conversation engine (all required for inbound mail to be answered; missing any
# one degrades the worker to a "not configured to receive emails" auto-reply).
# Cloudflare API token used for outbound email (SMTP password vs smtp.mx.cloudflare.net) AND
# for account linking / Email Routing + Worker auto-provisioning. Grant "Email Sending: Edit"
# plus Email Routing/DNS/Workers edit scopes for full drop-in setup. (was CF_EMAIL_TOKEN)
CF_API_TOKEN=cf-api-token

# Base support address; per-ticket reply aliases are derived as support+t<id>@<domain>.
# Its domain must be onboarded to Cloudflare Email Sending (DKIM/SPF) for outbound, and have a
# catch-all Email Routing rule to this worker for inbound.
SUPPORT_EMAIL=support@example.com

# Public site url used for the "view your ticket" link in the auto-ack (optional; has a fallback).
NUXT_PUBLIC_SITE_URL=https://smoke.pages.dev

# Inbound IMAP/POP3 mailbox poll (optional; an alternative to Cloudflare Email Routing for
# self-hosters). The mailbox is configured in the setup wizard / Settings and its password is
# sealed at rest in KV; these env vars are only a FALLBACK for the username/password when KV has
# none. Host/port/protocol/tls come from settings, not env.
POLL_USER=
POLL_PASS=

# Cloudflare Turnstile (optional bot protection for public forms: ticket submission, replies,
# file uploads, OTP requests). When BOTH keys are set, those actions require a captcha; when
# absent, protection is disabled (Settings shows a warning). Get real keys at
# https://dash.cloudflare.com/?to=/:account/turnstile. For local/dev use Cloudflare's always-pass
# test keys below (the server short-circuits them so no network is needed):
#   NUXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA      # always passes
#   NUXT_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA # always passes
# (2x... = always fails, 3x... = token already used, for testing the failure paths)
NUXT_PUBLIC_TURNSTILE_SITE_KEY=
NUXT_TURNSTILE_SECRET_KEY=
