# e2e / test env (non-secret placeholder values; loaded via --dotenv / --env-file)
MASTER_KEY=mmmmmmmmmmmmmmmmmmmmmmmmmmmmmmmm
HMAC_SECRET=hhhhhhhhhhhhhhhhhhhhhhhhhhhhhhhh
# mock the cloudflare api + enable the hydration marker / relaxed rate limit for e2e
MOCK_CF=1
NUXT_PUBLIC_E2E=1
SUPPORT_EMAIL=support@smoke.test
NUXT_PUBLIC_SITE_URL=http://127.0.0.1:4000
# turnstile: cloudflare's always-pass test keys (verifyTurnstile short-circuits these offline, so
# no network to challenges.cloudflare.com is needed). swap the site key for 2x.../3x... to test the
# fail paths. see https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NUXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
NUXT_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
