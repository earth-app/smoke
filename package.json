{
  "private": true,
  "name": "@earth-app/smoke",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx nuxi dev --no-restart --public --port 4000",
    "dev:test": "bunx nuxi dev --no-restart --public --port 4000 --dotenv .config/test.env",
    "dev:setup": "rm -rf .data-setup && NUXT_HUB_DIR=.data-setup NUXT_BUILD_DIR=.nuxt-setup bunx nuxi dev --no-restart --public --port 4001 --dotenv .config/setup.env",
    "dev:cloudflare": "bun run build && bunx wrangler dev --local --port 4000",
    "build": "nuxt build",
    "build:e2e": "bunx nuxi build --dotenv .config/test.env",
    "preview:e2e": "PORT=4000 node --env-file=.config/test.env .output/server/index.mjs",
    "test": "bunx vitest run",
    "test:watch": "bunx vitest",
    "test:coverage": "bunx vitest run --coverage",
    "test:report": "bunx vitest run --reporter=junit --outputFile=test-report.junit.xml",
    "test:integration": "INTEGRATION=1 bunx vitest run tests/integration --coverage",
    "test:e2e": "bunx playwright test",
    "test:e2e:setup": "PLAYWRIGHT_SETUP=1 bunx playwright test",
    "test:e2e:coverage": "bun run build:e2e && COVERAGE=1 bunx playwright test",
    "typecheck": "vue-tsc --build tsconfig.json",
    "types": "bunx wrangler types src/server/utils/worker-configuration.d.ts",
    "prettier": "bunx prettier --write .",
    "prettier:check": "bunx prettier --check .",
    "postinstall": "nuxt prepare",
    "prepare": "husky install"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@codecov/nuxt-plugin": "^2.0.1",
    "@earth-app/collegedb": "1.2.4",
    "@libsql/client": "^0.17.4",
    "@noble/hashes": "^2.2.0",
    "@nuxt/icon": "^2.3.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^4.4.8",
    "@nuxt/ui": "^4.9.0",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/i18n": "^10.4.1",
    "@nuxtjs/robots": "^6.1.2",
    "@nuxtjs/sitemap": "^8.2.2",
    "@nuxtjs/turnstile": "^1.1.3",
    "@pinia/nuxt": "^0.11.3",
    "@tiptap/extension-emoji": "^3.27.3",
    "@tiptap/extension-text-align": "^3.27.3",
    "@types/luxon": "^3.7.2",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "edgeport": "^1.0.3",
    "highlight.js": "^11.11.1",
    "luxon": "^3.7.2",
    "marked": "^16.4.2",
    "mimetext": "^3.0.28",
    "nuxt": "^4.4.8",
    "nuxt-api-shield": "^1.0.0",
    "nuxt-schema-org": "^6.2.3",
    "nuxt-viewport": "^2.4.0",
    "postal-mime": "^2.7.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@iconify-json/material-symbols": "^1.2.83",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/hints": "^1.1.3",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@vitest/coverage-istanbul": "^4.1.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "monocart-reporter": "^2.12.2",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wrangler": "^4.110.0"
  },
  "lint-staged": {
    "*.{ts,js,vue,css,json,md}": "prettier --write"
  }
}
