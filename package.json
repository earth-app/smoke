{
  "private": true,
  "name": "@earth-app/smoke",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bunx nuxi dev --no-restart --public --port 4000",
    "build": "nuxt build",
    "test": "vitest run",
