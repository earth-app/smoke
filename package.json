  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@iconify-json/material-symbols": "^1.2.78",
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/hints": "^1.1.3",
    "@types/bun": "^1.3.14",
    "@vitest/coverage-istanbul": "^4.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
