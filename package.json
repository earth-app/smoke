    "@noble/hashes": "^2.2.0",
    "@nuxt/icon": "^2.2.3",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^4.4.8",
    "@nuxt/ui": "^4.8.2",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/robots": "^6.1.1",
    "@nuxtjs/sitemap": "^8.2.1",
    "@nuxtjs/turnstile": "^1.1.3",
    "@pinia/nuxt": "^0.11.3",
    "@types/luxon": "^3.7.1",
    "bcryptjs": "^3.0.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "luxon": "^3.7.2",
    "mimetext": "^3.0.28",
    "nuxt": "^4.4.8",
    "nuxt-api-shield": "^0.10.2",
    "nuxt-schema-org": "^6.2.1",
    "nuxt-viewport": "^2.4.0",
    "postal-mime": "^2.7.4",
    "zod": "^4.4.3"
